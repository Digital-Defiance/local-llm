# Copy to local-llm.env and edit (local-llm.env is gitignored).
# Loaded automatically by local-llm.sh; shell exports override these values.

# Profile default: indexed | plain
# LLM_MODE=plain

# --- Models (Ollama names: tag included, e.g. llama3.2:latest) ---
# Index / embedding model (indexed profile only)
INDEX_MODEL=nomic-embed-text
# EMBEDDING_MODEL=nomic-embed-text   # same as INDEX_MODEL if you prefer this name

# Chat / data model (both profiles)
DATA_MODEL=qwen3.6:27b-q4_K_M
# LLM_MODEL=qwen3.6:27b-q4_K_M      # same as DATA_MODEL if you prefer this name
# CHAT_MODEL=...                     # alias for DATA_MODEL

# --- Ollama ---
# OLLAMA_HOST=http://localhost:11434

# --- Qdrant (indexed profile only) ---
# QDRANT_STORAGE=/path/to/qdrant_storage
# QDRANT_CONTAINER_NAME=qdrant
